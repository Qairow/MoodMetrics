{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],

    /* ✅ NodeNext — правильный вариант для Node.js ESM (TypeScript 5+) */
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": false,
    "sourceMap": false
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "prisma"]
}