{
  "name": "psycheck-server",
  "version": "0.1.0",
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/index.js",
    "seed": "tsx prisma/seed.ts",
    "postinstall": "prisma generate && prisma migrate deploy && prisma db seed --skip-generate"
  }
}